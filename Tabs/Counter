-- COUNTER GLOVE TAB SCRIPT
local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window
local Places = getgenv().sbstew_Places

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- Variables for Logic
local leverStartTime = nil

-- Logic for Keypad Status and Code
local function getKeypadInfo()
    local keypad = Workspace:FindFirstChild("Keypad")
    local status = "No"
    local code = (#Players:GetPlayers() * 25) + 1100 - 7
    
    if keypad then
        local pivot = keypad:GetPivot()
        if math.abs(pivot.X - (-427.55)) < 5 then
            status = "Yes (Slapple Island)"
        else
            status = "Yes (Moai Island)"
        end
    end
    return status, tostring(code)
end

local keypadStatus, currentCode = getKeypadInfo()

-- Create Tab
local CounterTab = Window:CreateTab("Counter Glove", "timer")
CounterTab:CreateLabel("Counter Glove Obtainment")

-- Keypad Status Paragraph
local StatusPara = CounterTab:CreateParagraph({
    Title = "Keypad Status",
    Content = string.format("Spawned: %s\nCode: %s", keypadStatus, currentCode)
})

-- Dynamic Update Loop for Paragraph
task.spawn(function()
    while task.wait(1) do
        local status, code = getKeypadInfo()
        StatusPara:Set({
            Title = "Keypad Status",
            Content = string.format("Spawned: %s\nCode: %s", status, code)
        })
        keypadStatus = status
        currentCode = code
    end
end)

-- 1. Go to Maze
CounterTab:CreateButton({
    Name = "Go to maze",
    Callback = function()
        if Places["Lobby3"] then
            local keypad = Workspace:FindFirstChild("Keypad")
            if keypad then
                local character = LocalPlayer.Character
                local humanoid = character and character:FindFirstChild("Humanoid")
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                
                if hrp and humanoid then
                    if character:FindFirstChild("InLobby") then
                        humanoid:MoveTo(Workspace.Lobby.Teleport1.Position)
                        humanoid.MoveToFinished:Wait()
                        task.wait(0.9)
                    end
                    
                    hrp.CFrame = keypad:GetPivot() * CFrame.new(0, 0, -3)
                    task.wait(0.5)
                    
                    if keypad.Buttons:FindFirstChild("Reset") then
                        fireclickdetector(keypad.Buttons.Reset.ClickDetector)
                        task.wait(0.3)
                    end
                    
                    local codeToEnter = currentCode
                    for i = 1, #codeToEnter do
                        local digit = string.sub(codeToEnter, i, i)
                        local button = keypad.Buttons:FindFirstChild(digit)
                        if button and button:FindFirstChild("ClickDetector") then
                            fireclickdetector(button.ClickDetector)
                            task.wait(0.35) -- Increased delay for reliability
                        end
                    end
                    fireclickdetector(keypad.Buttons.Enter.ClickDetector)
                end
            else
                Stewfield:Notify({
                    Title = "Not Found",
                    Content = "Keypad is not currently spawned.",
                    Duration = 4,
                    Image = "circle-alert",
                })
            end
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in Slap Battles main game to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

-- 2. Flip the Lever
local FlipButton
FlipButton = CounterTab:CreateButton({
    Name = "Flip the lever",
    Callback = function()
        if Places["Maze"] then
            local lever = Workspace:FindFirstChild("CounterLever")
            if lever and lever:FindFirstChild("ClickDetector") then
                fireclickdetector(lever.ClickDetector)
                leverStartTime = tick()
                
                if FlipButton then
                    FlipButton:Destroy()
                end

                Stewfield:Notify({
                    Title = "Lever Flipped",
                    Content = "Pim has spawned! Timer started. Wait 2 minutes for the glove to spawn.",
                    Duration = 5,
                    Image = "check-circle",
                })
            else
                Stewfield:Notify({
                    Title = "Error",
                    Content = "Lever not found! Ensure you are in the maze area.",
                    Duration = 4,
                    Image = "circle-alert",
                })
            end
        else
            Stewfield:Notify({
                Title = "Wrong Place",
                Content = "You must be in the Maze to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

-- 3. Destroy Pim
CounterTab:CreateButton({
    Name = "Destroy Pim",
    Callback = function()
        if Places["Maze"] then
            local npc = Workspace:FindFirstChild("Pim") 
            -- Logic to attempt Pim relocation
            if npc then
                local p_hrp = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Torso")
                if p_hrp then
                    local position = Vector3.new(-516.951111, 8.21111965, -141.350296)
                    local orientation = Vector3.new(1.00135803e-05, 7.00354576e-06, 1)
                    p_hrp.CFrame = CFrame.new(position, position + orientation)
                    
                    Stewfield:Notify({
                        Title = "Pim Destroyed",
                        Content = "Pim has been sent away. Teleporting to safety...",
                        Duration = 3,
                        Image = "trash-2",
                    })
                end
            else
                Stewfield:Notify({
                    Title = "Pim Not Found",
                    Content = "Pim isn't here, but teleporting to safety regardless.",
                    Duration = 3,
                    Image = "circle-alert",
                })
            end

            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            
            if hrp and hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
                task.wait(0.1)
                hrp.CFrame = CFrame.new(-7, 34, -37)
                
                Stewfield:Notify({
                    Title = "Safe Spot",
                    Content = "Teleported to safety. Wait for the timer to end.",
                    Duration = 3,
                    Image = "shield-check"
                })
            end
        else
            Stewfield:Notify({
                Title = "Wrong Place",
                Content = "You must be in the Maze to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

-- 4. Check Time Remaining
CounterTab:CreateButton({
    Name = "Check time remaining",
    Callback = function()
        if Places["Maze"] then
            if leverStartTime == nil then
                Stewfield:Notify({
                    Title = "Timer Not Started",
                    Content = "You must flip the lever first!",
                    Duration = 3,
                    Image = "circle-alert"
                })
            else
                local timeElapsed = tick() - leverStartTime
                local timeLeft = 121 - timeElapsed 

                if timeLeft <= 0 then
                    Stewfield:Notify({
                        Title = "Time Up!",
                        Content = "Counter glove has spawned! You can now collect it.",
                        Duration = 3,
                        Image = "hourglass"
                    })
                else
                    local minutes = math.floor(timeLeft / 60)
                    local seconds = math.floor(timeLeft % 60)
                    Stewfield:Notify({
                        Title = "Time Remaining",
                        Content = string.format("Glove spawns in: %d minutes and %d seconds", minutes, seconds),
                        Duration = 5,
                        Image = "hourglass"
                    })
                end
            end
        else
            Stewfield:Notify({
                Title = "Wrong Place",
                Content = "You must be in the Maze to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

-- 5. Tp to Counter Glove
CounterTab:CreateButton({
    Name = "Tp to counter glove",
    Callback = function()
        if Places["Maze"] then
            local timeElapsed = leverStartTime and (tick() - leverStartTime) or 0
            if leverStartTime == nil or timeElapsed < 121 then
                Stewfield:Notify({
                    Title = "Wait!",
                    Content = "The timer hasn't finished yet! Wait a little bit longer.",
                    Duration = 4,
                    Image = "clock"
                })
                return
            end

            local maze = Workspace:FindFirstChild("Maze")
            if maze then
                local parts = maze:GetChildren()
                local part = parts[673]
                if part and LocalPlayer.Character then
                    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        hrp.CFrame = part.CFrame * CFrame.new(0,-10, 0)
                        Stewfield:Notify({
                            Title = "Teleported",
                            Content = "Teleported to the Counter Glove location.",
                            Duration = 3,
                            Image = "map-pin"
                        })
                    end
                end
            else
                Stewfield:Notify({
                    Title = "Error",
                    Content = "Maze map not found.",
                    Duration = 4,
                    Image = "circle-alert"
                })
            end
        else
            Stewfield:Notify({
                Title = "Wrong Place",
                Content = "You must be in the Maze to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

CounterTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. Check the Keypad Status. If it says 'Yes', press 'Go to maze'.\n2. Once inside, press 'Flip the lever' to spawn Pim and start the timer.\n3. Press 'Destroy Pim' to remove the threat and teleport to safety.\n4. Wait 2 minutes. Use 'Check time remaining' to see when the glove spawns.\n5. Once the timer is up, press 'Tp to counter glove' then click on it to receive the badge."
})

return CounterTab
