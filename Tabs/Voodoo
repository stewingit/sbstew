-- VOODOO GLOVE TAB SCRIPT
local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window
local Places = getgenv().sbstew_Places

local LocalPlayer = game:GetService("Players").LocalPlayer

-- Create Tab
local VoodooTab = Window:CreateTab("Voodoo Glove", "skull")
VoodooTab:CreateLabel("Voodoo Glove Buttons")

-- Helper: Get Slaps and Glove
local function getStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

-- 1. Equip Ghost Glove
VoodooTab:CreateButton({
    Name = "Equip Ghost",
    Callback = function()
        local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) 
            and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")

        local slaps, _ = getStats()

        if LobbyPath then
            if slaps >= 666 then
                local GloveObj = Workspace.Lobby:WaitForChild("Ghost", 2)
                if GloveObj then
                    fireclickdetector(GloveObj:FindFirstChildOfClass("ClickDetector"))
                end
            else
                Stewfield:Notify({
                    Title = "Insufficient Slaps",
                    Content = "You need 666 slaps to equip Ghost!",
                    Duration = 5,
                    Image = "lock"
                })
            end
        else
            Stewfield:Notify({
                Title = "Error",
                Content = "Make sure you're in the lobby.",
                Duration = 5,
                Image = "circle-alert"
            })
        end
    end,
})

-- 2. Teleport to Safe Spot
local function Create(InstanceType, Properties, Children)
    local obj = Instance.new(InstanceType)
    for prop, val in pairs(Properties) do
        obj[prop] = val
    end
    if Children then
        for _, child in ipairs(Children) do
            child.Parent = obj
        end
    end
    obj.Parent = Properties.Parent
    return obj
end

VoodooTab:CreateButton({
    Name = "Teleport to Safe Spot",
    Callback = function()
        local _, currentGlove = getStats()
        
        if currentGlove ~= "Ghost" then
            Stewfield:Notify({
                Title = "Wrong Glove",
