                Anchored = true,
                CanCollide = true,
                Transparency = 0.5,
                Position = Vector3.new(-5500, -5000, -5000),
                Size = Vector3.new(21, 5, 21),
                Parent = workspace
            }, {
                Create("Part", {
                    Name = "S1",
                    Anchored = true,
                    CanCollide = true,
                    Transparency = 0.5,
                    Position = Vector3.new(-5499.91, -4991.5, -4989.09),
                    Size = Vector3.new(20, 13, 2)
                }),
                Create("Part", {
                    Name = "S2",
                    Anchored = true,
                    CanCollide = true,
                    Transparency = 0.5,
                    Size = Vector3.new(21, 14, 2),
                    CFrame = CFrame.new(-5510.27979, -4991.5, -5000.08984) * CFrame.Angles(0, math.rad(-90), 0),
                }),
                Create("Part", {
                    Name = "S3",
                    Anchored = true,
                    CanCollide = true,
                    Transparency = 0.5,
                    Position = Vector3.new(-5499.3, -4991.5, -5011.12),
                    Size = Vector3.new(21, 13, 2)
                }),
                Create("Part", {
                    Name = "S4",
                    Anchored = true,
                    CanCollide = true,
                    Transparency = 0.5,
                    Size = Vector3.new(22, 13, 2),
                    CFrame = CFrame.new(-5489.97559, -4991.5, -4999.52637) * CFrame.Angles(0, math.rad(-90), 0)
                }),
                Create("Part", {
                    Name = "S5",
                    Anchored = true,
                    CanCollide = true,
                    Transparency = 0.5,
                    Position = Vector3.new(-5499.39, -4984, -5000.07),
                    Size = Vector3.new(24, 3, 24)
                })
            })

            for _, v in ipairs(workspace.SafeBox:GetChildren()) do
                if v:IsA("BasePart") and v ~= workspace.SafeBox then
                    Create("WeldConstraint", {
                        Part0 = workspace.SafeBox,
                        Part1 = v,
                        Name = v.Name.." (Weld)",
                        Parent = workspace.SafeBox
                    })
                    v.Anchored = false
                end
            end
        end

        -- Walk to portal
        local portal = Workspace.Lobby.Teleport1
        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local Hum = character:WaitForChild("Humanoid")
        
        Hum:MoveTo(portal.Position)
        
        -- Wait until character touches portal
        local entered = false
        local connection
        connection = portal.Touched:Connect(function(hit)
            if hit:IsDescendantOf(character) then
                entered = true
                connection:Disconnect()
            end
        end)

        repeat task.wait() until entered
        
        task.wait(1)

        -- Teleport into SafeBox
        LocalPlayer.Character.HumanoidRootPart.CFrame = workspace.SafeBox.CFrame * CFrame.new(0, 5, 0)
    end,
})

-- 3. Begin (Fire Ability)
local startTime = nil
local BeginButton

BeginButton = VoodooTab:CreateButton({
    Name = "Begin",
    Callback = function()
        startTime = tick()

        local args = {}
        game:GetService("ReplicatedStorage"):WaitForChild("Ghostinvisibilityactivated"):FireServer(unpack(args))

        Stewfield:Notify({
            Title = "Ability Activated",
            Content = "Voodoo invisibility started.",
            Duration = 4,
            Image = "check"
        })

        if BeginButton then
            BeginButton:Destroy()
        end
    end,
})

-- 4. Anti-AFK Toggle
local AntiAFKConnection
local AntiAFKToggle = VoodooTab:CreateToggle({
    Name = "Anti-Disconnect",
    CurrentValue = false,
    Flag = "AntiAFK_Flag",
    Callback = function(Value)
        if Value then
            local VirtualUser = game:GetService("VirtualUser")
            AntiAFKConnection = LocalPlayer.Idled:Connect(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        else
            if AntiAFKConnection then
                AntiAFKConnection:Disconnect()
                AntiAFKConnection = nil
            end
        end
    end,
})

