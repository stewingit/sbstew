-- 6. Check Time Remaining
VoodooTab:CreateButton({
    Name = "Check Time Remaining",
    Callback = function()
        if startTime == nil then
            Stewfield:Notify({
                Title = "Timer Not Started",
                Content = "You must press 'Begin' first!",
                Duration = 3,
                Image = "circle-alert"
            })
        else
            local timeElapsed = tick() - startTime
            local timeLeft = 3600 - timeElapsed

            if timeLeft <= 0 then
                Stewfield:Notify({
                    Title = "Time Up!",
                    Content = "The hour is up! You should get the badge now or very soon.",
                    Duration = 3,
                    Image = "hourglass"
                })
            else
                local minutes = math.floor(timeLeft / 60)
                local seconds = math.floor(timeLeft % 60)
                Stewfield:Notify({
                    Title = "Time Remaining",
                    Content = string.format("Remaining: %d minutes and %d seconds", minutes, seconds),
                    Duration = 5,
                    Image = "hourglass"
                })
            end
        end
    end,
})

return VoodooTab
