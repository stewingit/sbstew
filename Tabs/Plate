-- PLATE GLOVE TAB SCRIPT
if not getgenv().sbstew_Utils then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Stuff"))()
end

local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window
local Places = getgenv().sbstew_Places
local Utils = getgenv().sbstew_Utils
local LocalPlayer = game.Players.LocalPlayer

local PlateTab = Window:CreateTab("Plate Glove", "disc")
PlateTab:CreateLabel("Plate Glove Buttons")

PlateTab:CreateButton({
    Name = "Go to plate place",
    Callback = function()
        if not Utils.IsInLobby() then
            Stewfield:Notify({
                Title = "Required",
                Content = "You must be in the Lobby.",
                Duration = 4,
                Image = "circle-alert",
            })
            return
        end

        if Places["Lobby3"] then    
            getgenv().PlateSlapActive = false
            task.wait(0.1)

            local character = LocalPlayer.Character
            local hum = character:FindFirstChildOfClass("Humanoid")
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            local targetPlate = workspace.Arena.Plate
            local targetText = workspace.Arena.Plate.Sign.Text

            Utils.WalkToPortal()
            
            local start = tick()
            repeat task.wait() until not Utils.IsInLobby() or (tick() - start > 5)
            task.wait(0.5) 

            if hum and rootPart and targetPlate and targetText then
                hum.Jump = true 
                task.wait(0.1)
                
                local platePos = targetPlate.Position
                local signPos = targetText.Position
                
                rootPart.CFrame = CFrame.lookAt(
                    Vector3.new(platePos.X, platePos.Y + 3, platePos.Z), 
                    Vector3.new(signPos.X, platePos.Y + 3, signPos.Z)
                )
                task.wait(0.2)
            end

            getgenv().PlateSlapActive = true
            Stewfield:Notify({
                Title = "Auto Slap",
                Content = "Started slapping",
                Duration = 3,
                Image = "info",
            })

            task.spawn(function()
                while getgenv().PlateSlapActive do
                    local char = LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    local tool = char and char:FindFirstChildOfClass("Tool")
                    
                    if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
                        getgenv().PlateSlapActive = false
                        break
                    end

                    if tool then
                        local handle = tool:FindFirstChild("Handle") or tool:FindFirstChildOfClass("Part")
                        if handle then
                            handle.Size = Vector3.new(15, 15, 15)
                            handle.CanCollide = false
                            handle.Transparency = 1
                        end
                        tool:Activate()
                    end

                    if root and targetText then
                        local signPos = targetText.Position
                        root.CFrame = CFrame.lookAt(
                            root.Position, 
                            Vector3.new(signPos.X, root.Position.Y, signPos.Z)
                        )
                    end
                    task.wait(0.1)
                end
            end)
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in the Slap Battles Lobby to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

PlateTab:CreateToggle({
    Name = "Delete all obstacles",
    CurrentValue = false,
    Flag = "DeleteObstacles_Flag",
    Callback = function(Value)
        if Places["Plate"] then
            local obstacles = workspace:FindFirstChild("Obstacles") or game:GetService("ReplicatedStorage"):FindFirstChild("Obstacles")
            
            if Value then
                if obstacles then
                    obstacles.Parent = game:GetService("ReplicatedStorage")
                    Stewfield:Notify({
                        Title = "Success",
                        Content = "All obstacles removed!",
                        Duration = 3,
                        Image = "check",
                    })
                end
            else
                if obstacles then
                    obstacles.Parent = workspace
                    Stewfield:Notify({
                        Title = "Restored",
                        Content = "Obstacles have returned.",
                        Duration = 3,
                        Image = "info",
                    })
                end
            end
            
            if Value then
                task.spawn(function()
                    local connection
                    connection = workspace:GetAttributeChangedSignal("Completed"):Connect(function()
                        if workspace:GetAttribute("Completed") == true then
                            Stewfield:Notify({
                                Title = "Notification",
                                Content = "Task finished!",
                                Duration = 5,
                                Image = "check",
                            })
                            connection:Disconnect()
                        end
                    end)
                end)
            end
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in the Plate obtainment place to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

PlateTab:CreateButton({
    Name = "Go to glove",
    Callback = function()
        if Places["Plate"] then
            local character = LocalPlayer.Character
            local target = workspace:FindFirstChild("Glove Model") and workspace["Glove Model"]:FindFirstChild("Hand")
            
            if target then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                local hum = character:FindFirstChildOfClass("Humanoid")
                
                if rootPart and hum then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait(0.05)
                    rootPart.CFrame = target.CFrame
                end
            else
                Stewfield:Notify({
                    Title = "Not Spawned",
                    Content = "The glove has not spawned yet!",
                    Duration = 4,
                    Image = "circle-alert",
                })
            end
        else
            Stewfield:Notify({
                Title = "Wrong Game",
                Content = "You must be in the Plate place to use this.",
                Duration = 4,
                Image = "circle-alert",
            })
        end
    end,
})

PlateTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. Use 'Go to plate place' while in the Lobby.\n2. Once in the Plate place, toggle 'Delete all obstacles'.\n3. Wait for the 'Done' notification.\n4. Click 'Go to glove' to claim the badge."
})

return PlateTab
