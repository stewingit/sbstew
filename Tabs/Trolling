-- Void Coordinates
local VoidPositions = {
    Vector3.new(101, -107, 24),    -- Original
    Vector3.new(-3.6, -107, 115.4), -- Pos 1
    Vector3.new(-116.3, -107, 0.5), -- Pos 2
    Vector3.new(-4.7, -107, -111.1) -- Pos 3
}

-- Remote Protection Hook
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if TrollingActive and self == SLOC_Remote and (method == "FireServer" or method == "fireServer") then
        if not checkcaller() then
            return nil
        end
    end
    return oldNamecall(self, ...)
end)

-- Helper logic for Stats
local function getStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

-- Full Rock Sensing
local function IsValidTarget(p)
    local Character = p.Character
    if not Character then return false end
    
    local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
    local Root = Character:FindFirstChild("HumanoidRootPart")
    if not Humanoid or not Root or Humanoid.Health <= 0 then return false end

    -- Rock Logic
    local InLobby = Character:FindFirstChild("InLobby")
    local Rock = Character:FindFirstChild("rock") or Character:FindFirstChild("megarock")
    local Steve = Character:FindFirstChild("stevebody")

    return (not Rock and not Steve and not InLobby)
end

-- Helper logic to find the closest valid player name
local function getClosestPlayerName()
    local closestName = nil
    local shortestDist = math.huge
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not myRoot then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and IsValidTarget(p) then
            local dist = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closestName = p.Name
            end
        end
    end
    return closestName
end

