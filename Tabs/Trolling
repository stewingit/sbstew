local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MarketPlaceService = game:GetService("MarketplaceService")

-- Configuration & State
local TrollCount = 1
local TrollingActive = false
local SelectedTroll = "cube of death"
local ResetRemote = ReplicatedStorage:WaitForChild("SelfDestruct", 5) or ReplicatedStorage:WaitForChild("Reset", 5)

-- Helper logic for Stats
local function getStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

-- Tab Creation
local TrollingTab = Window:CreateTab("Trolling", "laugh")

-- Death Handler Logic
local function MonitorDeath(character)
    local humanoid = character:WaitForChild("Humanoid", 10)
    if humanoid then
        humanoid.Died:Connect(function()
            if TrollingActive then
                TrollingActive = false
                -- This visually updates the toggle in the UI and stops the loop logic
                TrollingTab:Set({Flag = "TrollToggle", Value = false})
                Stewfield:Notify({
                    Title = "Script Stopped",
                    Content = "Character died. Trolling disabled.",
                    Duration = 3,
                    Image = "skull"
                })
            end
        end)
    end
end

-- Initialize death monitoring for current and future characters
if LocalPlayer.Character then task.spawn(MonitorDeath, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(MonitorDeath)

-- Main Logic Function
local function RunTrollLogic()
    local char = LocalPlayer.Character
    if not char then return end
    
    local _, glove = getStats()
    
    -- Ownership/Equip Check
    if glove ~= "Swapper" then
        TrollingTab:Set({Flag = "TrollToggle", Value = false})
        Stewfield:Notify({
            Title = "Glove Required",
            Content = "You must have Swapper equipped to use this!",
            Duration = 5,
            Image = "circle-alert"
        })
        return
    end

    -- Movement to Portal
    local portal = Workspace.Lobby:FindFirstChild("Teleport1")
    if portal and char:FindFirstChild("Humanoid") then
        char.Humanoid:MoveTo(portal.Position)
        
        -- Wait for teleport
        repeat task.wait(0.1) until (char:FindFirstChild("InLobby") == nil) or not TrollingActive
        
        if not TrollingActive then return end
        task.wait(0.5)

        -- Execution Loop
        local cubePath = Workspace.Arena.CubeOfDeathArea:FindFirstChild("the cube of death(i heard it kills)")
        local remote = ReplicatedStorage:WaitForChild("SLOC", 5)
        local rootPart = char:FindFirstChild("HumanoidRootPart")

        for i = 1, TrollCount do
            if not TrollingActive then break end
            
            if cubePath and rootPart then
                -- Disable Kill Part
                cubePath.CanTouch = false
                if cubePath:FindFirstChild("Part") then
                    cubePath.Part.CanTouch = false
                end

                -- Teleport
                rootPart.CFrame = cubePath.CFrame * CFrame.new(0, 5, 0)
                task.wait(0.5)

                -- Fire Remote
                if remote then
                    remote:FireServer()
                end
            end

            if i < TrollCount then
                task.wait(7)
            end
        end
    end
end

TrollingTab:CreateLabel("Swapper Trolling")

-- UI Components
TrollingTab:CreateDropdown({
    Name = "Type",
    Options = {"cube of death"},
    CurrentOption = "cube of death",
    MultipleOptions = false,
    Callback = function(Option)
        SelectedTroll = Option[1]
    end,
})

TrollingTab:CreateSlider({
    Name = "Amount of Trolls",
    Range = {1, 50},
    Increment = 1,
    Suffix = " Times",
    CurrentValue = 1,
    Callback = function(Value)
        TrollCount = Value
    end,
})

TrollingTab:CreateToggle({
    Name = "Swapper Trolling",
    CurrentValue = false,
    Flag = "TrollToggle",
    Callback = function(Value)
        TrollingActive = Value
        
        if TrollingActive then
            task.spawn(RunTrollLogic)
        else
            -- Check if character is still alive before forcing a reset 
            -- (prevents double-reset if the death handler already stopped it)
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character.Humanoid.Health > 0 then
                if ResetRemote then
                    ResetRemote:FireServer()
                else
                    LocalPlayer.Character.Humanoid.Health = 0
                end
            end
        end
    end,
})

TrollingTab:CreateLabel("Instructions")
TrollingTab:CreateParagraph({
    Title = "How to use",
    Content = "• Equip the Swapper glove in the lobby.\n" ..
              "• Set the amount of times you wish to loop the teleport.\n" ..
              "• Enable 'Swapper Trolling' to begin the automation.\n" ..
              "• If you die, the script will automatically turn off.\n" ..
              "• Manually disabling the toggle will reset your character."
})

return TrollingTab
