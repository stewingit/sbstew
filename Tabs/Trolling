local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MarketPlaceService = game:GetService("MarketplaceService")

-- Configuration & State
local TrollCount = 1
local TrollingActive = false
local SelectedTroll = "cube of death"
local ResetRemote = ReplicatedStorage:WaitForChild("SelfDestruct", 5) or ReplicatedStorage:WaitForChild("Reset", 5)

-- Helper logic for Stats
local function getStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

-- Tab Creation
local TrollingTab = Window:CreateTab("Trolling", "laugh")

local TrollingToggle

-- Lobby Check Logic
task.spawn(function()
    while task.wait(0.5) do
        if TrollingActive then
            local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")
            if LobbyPath then
                TrollingActive = false
                if TrollingToggle then TrollingToggle:Set(false) end
                Stewfield:Notify({
                    Title = "Script Stopped",
                    Content = "Back in lobby. Trolling disabled.",
                    Duration = 3,
                    Image = "map"
                })
            end
        end
    end
end)

-- Main Logic Function
local function RunTrollLogic()
    local char = LocalPlayer.Character
    if not char then return end
    
    local _, glove = getStats()
    local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")

    -- 1. Arena Check (Ensures you are not in the lobby)
    if LobbyPath then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        Stewfield:Notify({
            Title = "Arena Required",
            Content = "Please enter the arena before turning this on!",
            Duration = 5,
            Image = "circle-alert"
        })
        return
    end
    
    -- 2. Ownership/Equip Check
    if glove ~= "Swapper" then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        Stewfield:Notify({
            Title = "Glove Required",
            Content = "You must have Swapper equipped to use this!",
            Duration = 5,
            Image = "circle-alert"
        })
        return
    end

    -- 3. Execution Loop
    task.wait(0.5)

    local cubePath = Workspace.Arena.CubeOfDeathArea:FindFirstChild("the cube of death(i heard it kills)")
    local remote = ReplicatedStorage:WaitForChild("SLOC", 5)
    local rootPart = char:FindFirstChild("HumanoidRootPart")

    for i = 1, TrollCount do
        if not TrollingActive then break end
        
        if cubePath and rootPart then
            -- Disable Kill Part
            cubePath.CanTouch = false
            if cubePath:FindFirstChild("Part") then
                cubePath.Part.CanTouch = false
            end

            -- Teleport
            rootPart.CFrame = cubePath.CFrame * CFrame.new(0, 5, 0)
            task.wait(0.5)

            -- Fire Remote
            if remote then
                remote:FireServer()
            end
        end

        if i < TrollCount then
            task.wait(7)
        end
    end
    
    -- Finish Tasks: Reset and turn off toggle
    if TrollingActive then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        
        -- Reset Character after finishing iterations
        if ResetRemote then
            ResetRemote:FireServer()
        else
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.Health = 0
            end
        end
    end
end

TrollingTab:CreateLabel("Swapper Trolling")

-- UI Components
TrollingTab:CreateDropdown({
    Name = "Type",
    Options = {"cube of death"},
    CurrentOption = "cube of death",
    MultipleOptions = false,
    Callback = function(Option)
        SelectedTroll = Option[1]
    end,
})

TrollingTab:CreateSlider({
    Name = "Amount of Trolls",
    Range = {1, 50},
    Increment = 1,
    Suffix = " Times",
    CurrentValue = 1,
    Callback = function(Value)
        TrollCount = Value
    end,
})

TrollingToggle = TrollingTab:CreateToggle({
    Name = "Swapper Trolling",
    CurrentValue = false,
    Flag = "TrollToggle",
    Callback = function(Value)
        TrollingActive = Value
        
        if TrollingActive then
            task.spawn(RunTrollLogic)
        else
            -- Manual disable: Check if in arena to reset
            local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")
            if not LobbyPath and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character.Humanoid.Health > 0 then
                if ResetRemote then
                    ResetRemote:FireServer()
                else
                    LocalPlayer.Character.Humanoid.Health = 0
                end
            end
        end
    end,
})

TrollingTab:CreateLabel("Instructions")
TrollingTab:CreateParagraph({
    Title = "How to use",
    Content = "• Equip the Swapper glove in the lobby.\n" ..
              "• Enter the arena first.\n" ..
              "• Set the amount of times you wish to loop the teleport.\n" ..
              "• Enable 'Swapper Trolling' to begin.\n" ..
              "• The script turns off automatically if you finish or return to lobby."
})

return TrollingTab
