    end,
})
RefreshPlayerList()

TrollingTab:CreateSlider({
    Name = "Amount of Trolls",
    Range = {1, 50},
    Increment = 1,
    Suffix = " Times",
    CurrentValue = 1,
    Callback = function(Value)
        TrollCount = Value
    end,
})

TrollingToggle = TrollingTab:CreateToggle({
    Name = "Swapper Trolling",
    CurrentValue = false,
    Flag = "TrollToggle",
    Callback = function(Value)
        TrollingActive = Value
        
        if TrollingActive then
            task.spawn(RunTrollLogic)
        else
            local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")
            if not LobbyPath and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character.Humanoid.Health > 0 then
                if ResetRemote then
                    ResetRemote:FireServer()
                else
                    LocalPlayer.Character.Humanoid.Health = 0
                end
            end
        end
    end,
})

