local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MarketPlaceService = game:GetService("MarketplaceService")

-- Configuration & State
local TrollCount = 1
local TrollingActive = false
local SelectedTroll = "void"
local SelectedTarget = "Random"
local ResetRemote = ReplicatedStorage:WaitForChild("SelfDestruct", 5) or ReplicatedStorage:WaitForChild("Reset", 5)
local SLOC_Remote = ReplicatedStorage:WaitForChild("SLOC", 5)

-- Remote Protection Hook
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if TrollingActive and self == SLOC_Remote and (method == "FireServer" or method == "fireServer") then
        if not checkcaller() then
            return nil
        end
    end
    return oldNamecall(self, ...)
end)

-- Helper logic for Stats
local function getStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

-- Helper logic to find the closest player name
local function getClosestPlayerName()
    local closestName = nil
    local shortestDist = math.huge
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if not myRoot then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closestName = p.Name
            end
        end
    end
    return closestName
end

-- Tab Creation
local TrollingTab = Window:CreateTab("Trolling", "laugh")

local TrollingToggle
local TargetDropdown

-- Dropdown Refresh Logic
local function RefreshPlayerList()
    local playerNames = {"Random"}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            table.insert(playerNames, p.Name)
        end
    end
    if TargetDropdown then
        TargetDropdown:Refresh(playerNames)
    end
end

Players.PlayerAdded:Connect(RefreshPlayerList)
Players.PlayerRemoving:Connect(RefreshPlayerList)

-- Lobby Check Logic
task.spawn(function()
    while task.wait(0.5) do
        if TrollingActive then
            local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")
            if LobbyPath then
                TrollingActive = false
                if TrollingToggle then TrollingToggle:Set(false) end
                Stewfield:Notify({
                    Title = "Script Stopped",
                    Content = "Back in lobby. Trolling disabled.",
                    Duration = 3,
                    Image = "map"
                })
            end
        end
    end
end)

-- Main Logic Function
local function RunTrollLogic()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not hum or not rootPart then return end
    
    local _, glove = getStats()
    local LobbyPath = Workspace:FindFirstChild(LocalPlayer.Name) and Workspace[LocalPlayer.Name]:FindFirstChild("InLobby")

    -- 1. Arena Check
    if LobbyPath then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        Stewfield:Notify({
            Title = "Arena Required",
            Content = "Please enter the arena before turning this on!",
            Duration = 5,
            Image = "circle-alert"
        })
        return
    end
    
    -- 2. Ownership/Equip Check
    if glove ~= "Swapper" then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        Stewfield:Notify({
            Title = "Glove Required",
            Content = "You must have Swapper equipped to use this!",
            Duration = 5,
            Image = "circle-alert"
        })
        return
    end

    -- 3. Execution Loop
    task.wait(0.5)

    -- Creation of Void Part if selected
    local voidPart
    if SelectedTroll == "void" then
        voidPart = Instance.new("Part")
        voidPart.Name = "S5"
        voidPart.Anchored = true
        voidPart.CanCollide = true
        voidPart.Transparency = 0.5
        voidPart.Position = Vector3.new(101, -107, 24)
        voidPart.Size = Vector3.new(24, 3, 24)
        voidPart.Parent = Workspace
    end

    for i = 1, TrollCount do
        if not TrollingActive then break end

        -- Step A: Position User at the Death Point
        if SelectedTroll == "cube of death" then
            local cubePath = Workspace.Arena.CubeOfDeathArea:FindFirstChild("the cube of death(i heard it kills)")
            if cubePath then
                cubePath.CanTouch = false
                if cubePath:FindFirstChild("Part") then
                    cubePath.Part.CanTouch = false
                end
                rootPart.CFrame = cubePath.CFrame * CFrame.new(0, 5, 0)
            end
        elseif SelectedTroll == "void" then
            if voidPart then
                rootPart.CFrame = voidPart.CFrame * CFrame.new(0, 5, 0)
            end
        end

        -- Step B: Wait for the specific target to be the closest (if not Random)
        if SelectedTarget ~= "Random" then
            local notify = Stewfield:Notify({
                Title = "Targeting",
                Content = "Waiting for " .. SelectedTarget .. " to get close...",
                Duration = 5,
                Image = "clock"
            })
            
            repeat
                task.wait(0.1)
                -- Check if target still exists or script was disabled
                if not Players:FindFirstChild(SelectedTarget) or not TrollingActive then break end
            until getClosestPlayerName() == SelectedTarget
        end

        -- Step C: Trigger Swap
        task.wait(0.3) -- Brief buffer to ensure position is registered
        if SLOC_Remote and TrollingActive then
            SLOC_Remote:FireServer()
        end

        -- Step D: Cool-down for Swapper Ability
        if i < TrollCount then
            task.wait(7)
        end
    end
    
    -- Cleanup
    if voidPart then voidPart:Destroy() end
    
    if TrollingActive then
        TrollingActive = false
        if TrollingToggle then TrollingToggle:Set(false) end
        
        if ResetRemote then
            ResetRemote:FireServer()
        else
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                LocalPlayer.Character.Humanoid.Health = 0
            end
        end
    end
end

TrollingTab:CreateLabel("Swapper Trolling")

