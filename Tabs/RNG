-- RNG GLOVE TAB SCRIPT

if not getgenv().sbstew_Utils then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Stuff"))()
end

local Stewfield = getgenv().sbstew_Stewfield
local Window = getgenv().sbstew_Window
local Places = getgenv().sbstew_Places
local Utils = getgenv().sbstew_Utils
local Remotes = getgenv().sbstew_Remotes

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- Utilizing shared values from Utils
local ZeroPosition = Utils.GetZeroPosition()
local RoamRange = Utils.RoamRange
local MaxLockDistance = Utils.MaxLockDistance
local AcceptableDistance = Utils.AcceptableDistance
local TargetGlove = "Dice"

local SlapRemote = Remotes.Slap.Dice
local SlapAnimation = ReplicatedStorage.Slap
local Reset = Remotes.Misc.PlayerReset

local LockedTarget = nil
local SlapCooldown = false
local LocalHumanoid = nil
local Animation = nil
local InfiniteMode = false

local RNGTab = Window:CreateTab("RNG Glove", "dice-5")
RNGTab:CreateLabel("RNG Glove Obtainment")

-- Utilising
local function CharacterLoaded(Character)
    local Hum, Anim = Utils.SetupBotSupport(Character, SlapAnimation)
    LocalHumanoid = Hum
    Animation = Anim
end

local function GetTarget()
    local ClosestPlayer = nil
    local ShortestDistance = MaxLockDistance

    for _, v in ipairs(Players:GetPlayers()) do
        local Character = v.Character
        if v ~= LocalPlayer and Character and not LocalPlayer:IsFriendsWith(v.UserId) then
            local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local Root = Humanoid.RootPart
                if Root then
                    local Distance = (LocalHumanoid.RootPart.Position - Root.Position).Magnitude
                    local InMap = (Root.Position - ZeroPosition).Magnitude < RoamRange
                    
                    if InMap and Distance < ShortestDistance and Utils.IsTargetValid(Character) then
                        ClosestPlayer = v
                        ShortestDistance = Distance
                    end
                end
            end
        end
    end
    return ClosestPlayer, ShortestDistance
end

local function StartLoops()
    task.spawn(function()
        while getgenv().RNG_Farm do
            local Character = LocalPlayer.Character
            if LocalHumanoid and LocalHumanoid.RootPart and Character then
                if not Utils.IsInLobby(Character) then
                    local TargetPlayer, Distance = GetTarget()

                    if TargetPlayer and TargetPlayer.Character then
                        local TargetRoot = TargetPlayer.Character:FindFirstChildWhichIsA("Humanoid").RootPart
                        if LocalHumanoid.Health > 0 and TargetRoot then
                            local TargetPosition = TargetRoot.Position + Utils.ReturnValidVector3Unit(TargetRoot.AssemblyLinearVelocity)
                            LocalHumanoid:MoveTo(TargetPosition)

                            if Distance < AcceptableDistance and not SlapCooldown then
                                SlapCooldown = true
                                Animation:Play()
                                SlapRemote:FireServer(TargetPlayer.Character:FindFirstChild("Left Arm") or TargetRoot)
                                task.delay(0.6, function() SlapCooldown = false end)
                            end
                        end
                    else
                        LocalHumanoid:MoveTo(LocalHumanoid.RootPart.Position)
                    end
                else
                    local _, currentGlove = Utils.GetStats()
                    if currentGlove ~= TargetGlove then
                        Utils.EquipGlove(TargetGlove)
                    else
                        Utils.WalkToPortal()
                    end
                end
            end
            RunService.RenderStepped:Wait()
        end
    end)

    task.spawn(function()
        while task.wait(0.3) do
            if not getgenv().RNG_Farm then break end
            local Character = LocalPlayer.Character

            if LocalHumanoid and Character then
                if not Utils.IsInLobby(Character) then
                    for _, v in ipairs(Character:GetChildren()) do
                        if v:IsA("BasePart") then v.CanTouch = false end
                    end
                end

                if not Character:FindFirstChildWhichIsA("Tool") and LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool") then
                    LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool").Parent = Character
                end
            end
        end
    end)
end

LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if getgenv().RNG_Farm then
        CharacterLoaded(char)
        StartLoops()
    end
end)

RNGTab:CreateButton({
    Name = "Equip Dice glove",
    Callback = function()
        if Utils.IsInLobby() then
            local slaps, _ = Utils.GetStats()
            if slaps >= 585 then
                Utils.EquipGlove("Dice")
            else
                Stewfield:Notify({
                    Title = "Insufficient Slaps",
                    Content = "You need 585 slaps to equip Dice!",
                    Duration = 5,
                    Image = "lock"
                })
            end
        else
            Stewfield:Notify({
                Title = "Error",
                Content = "Make sure you're in the lobby.",
                Duration = 5,
                Image = "circle-alert"
            })
        end
    end,
})

RNGTab:CreateToggle({
    Name = "Get RNG",
    CurrentValue = false,
    Flag = "AutoRNG_Flag",
    Callback = function(Value)
        getgenv().RNG_Farm = Value
        if Value then
            Utils.StartSafetyLoop()
            
            local _, currentGlove = Utils.GetStats()

            if currentGlove == "Dice" then
                if LocalPlayer.Character then
                    CharacterLoaded(LocalPlayer.Character)
                    StartLoops()
                end
            else
                Stewfield:Notify({
                    Title = "Glove Required",
                    Content = "You must have the Dice glove equipped first!",
                    Duration = 5,
                    Image = "lock"
                })
            end
        else
            Utils.StopSafetyLoop()
        end
    end,
})

RNGTab:CreateParagraph({
    Title = "Instructions",
    Content = "1. Press 'Equip Dice'\n2. Toggle 'Get RNG' to start farming.\n3. The bot will go forever until the toggle is off."
})

return RNGTab
