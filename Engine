-- [[ BOT ENGINE LIBRARY - V2 ]] --
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local Grass = Workspace.Arena["main island"].Grass
local ZeroPosition = Grass.Position
local BotSpeed = 21
local RoamRange = 180
local MaxLockDistance = 80
local AcceptableDistance = 15

-- Remote Library
local Remotes = {
    Slap = {
        Default = ReplicatedStorage:WaitForChild("b", 2),
        Dual = ReplicatedStorage:WaitForChild("GeneralHit", 2),
        Snow = ReplicatedStorage:WaitForChild("SnowHit", 2),
        Warp = ReplicatedStorage:WaitForChild("WarpHt", 2),
        Dice = ReplicatedStorage:WaitForChild("DiceHit", 2),
        Swapper = ReplicatedStorage:WaitForChild("HitSwapper", 2)
    },
    Ability = {
        Warp = ReplicatedStorage:WaitForChild("WLOC", 2),
        Swapper = ReplicatedStorage:WaitForChild("SLOC", 2)
    },
    Misc = {
        Reset = ReplicatedStorage:WaitForChild("SelfDestruct", 2) or ReplicatedStorage:WaitForChild("Reset", 2),
        PlayerReset = LocalPlayer:FindFirstChild("Reset"),
    }
}

local BotEngine = {
    LockedTarget = nil,
    SlapCooldown = false
}
getgenv().BotEngine = BotEngine

-- [[ HELPER COMMANDS ]] --

function BotEngine.GetStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

function BotEngine.IsInLobby(Character)
    Character = Character or LocalPlayer.Character
    return Character and Character:FindFirstChild("InLobby")
end

function BotEngine.ReturnValidVector3Unit(Vector)
    if Vector.Magnitude == 0 then return Vector3.zero end
    return Vector.Unit
end

function BotEngine.GetPredictedPosition(RootPart)
    if not RootPart then return Vector3.zero end
    return RootPart.Position + BotEngine.ReturnValidVector3Unit(RootPart.AssemblyLinearVelocity)
end

-- [[ CHARACTER SETUP ]] --

function BotEngine.SetupCharacter(Character)
    local Humanoid = Character:WaitForChild("Humanoid", 10)
    Humanoid.AutomaticScalingEnabled = false
    Humanoid.HipHeight = 0.1

    -- Bot Support (Physics stabilization)
    local Root = Character:WaitForChild("HumanoidRootPart")
    local Support = Root:FindFirstChild("Bot Support") or Instance.new("BodyPosition")
    Support.Position = ZeroPosition
    Support.MaxForce = Vector3.new(200, 0, 200)
    Support.Name = "Bot Support"
    Support.Parent = Root
    
    return Humanoid
end

-- [[ LOBBY COMMANDS ]] --

function BotEngine.WalkToPortal()
    local Character = LocalPlayer.Character
    if Character and BotEngine.IsInLobby(Character) then
        local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
        local Portal = Workspace.Lobby:FindFirstChild("Teleport1")
        if Humanoid and Portal then
            Humanoid:MoveTo(Portal.Position)
        end
    end
end

function BotEngine.EquipGlove(GloveName)
    local GloveObj = Workspace.Lobby:WaitForChild(GloveName, 2)
    if GloveObj then
        local ClickDetector = GloveObj:FindFirstChildOfClass("ClickDetector")
        if ClickDetector then
            fireclickdetector(ClickDetector)
        end
    end
end

-- [[ TARGETING COMMANDS ]] --

function BotEngine.GetValidTarget(LocalHumanoid, SpecificRange)
    local ClosestPlayer = nil
    local ShortestDistance = SpecificRange or MaxLockDistance
    
    for _, v in ipairs(Players:GetPlayers()) do
        local Character = v.Character
        if v ~= LocalPlayer and Character and not LocalPlayer:IsFriendsWith(v.UserId) then
            local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                local Root = Humanoid.RootPart
                if Root then
                    local Distance = (LocalHumanoid.RootPart.Position - Root.Position).Magnitude
                    local InMap = (Root.Position - ZeroPosition).Magnitude < RoamRange
                    
                    -- Filter Logic
                    local InLobby = Character:FindFirstChild("InLobby")
                    local Rock = Character:FindFirstChild("rock") or Character:FindFirstChild("megarock")
                    local Reverse = Character:FindFirstChild("Reversed")
                    local Skull = Character:FindFirstChild("Skull")
                    local Counter = Character:FindFirstChild("Counterd")
                    local Steve = Character:FindFirstChild("stevebody")
                    local Visible = Character:FindFirstChild("CarKeysCar") or (Character:FindFirstChild("Head") or Character:FindFirstChildWhichIsA("BasePart")).Transparency == 0
                    local BuddyBox = Character:FindFirstChild("Head") and Character.Head:FindFirstChild("BuddyBox")
                    local Ragdolled = Character:FindFirstChild("FakePart Right Arm")

                    local Approved = (InMap and Distance < ShortestDistance and not Rock and not Reverse and not Steve and not Skull and Visible and not BuddyBox and not Ragdolled and not InLobby and not Counter)

                    if Approved then
                        ClosestPlayer = v
                        ShortestDistance = Distance
                    end
                end
            end
        end
    end
    return ClosestPlayer, ShortestDistance
end

-- [[ WARP SPECIFIC LOGIC ]] --

function BotEngine.ToggleWarpObtainment(Value)
    getgenv().BSF = Value
    if not Value then 
        BotEngine.LockedTarget = nil
        return 
    end

    task.spawn(function()
        while getgenv().BSF do
            local Character = LocalPlayer.Character
            local Humanoid = Character and Character:FindFirstChild("Humanoid")
            
            if Humanoid and Humanoid.RootPart and Character then
                if not BotEngine.IsInLobby(Character) then
                    -- 1. Persistent Target Locking
                    local Target = BotEngine.LockedTarget
                    local IsValid = false
                    
                    if Target and Target.Character and Target.Character:FindFirstChild("Humanoid") then
                        local TRoot = Target.Character.Humanoid.RootPart
                        local InRange = TRoot and (TRoot.Position - ZeroPosition).Magnitude < RoamRange
                        if Target.Character.Humanoid.Health > 0 and InRange then
                            IsValid = true
                        end
                    end

                    if not IsValid then
                        -- If we had a target and lost them, perform the Warp sequence
                        if BotEngine.LockedTarget then
                            getgenv().BSF = false
                            BotEngine.LockedTarget = nil
                            task.spawn(function()
                                task.wait(0.35)
                                if Remotes.Ability.Swapper then Remotes.Ability.Swapper:FireServer() end
                                task.wait(1)
                                if Remotes.Misc.PlayerReset then Remotes.Misc.PlayerReset:FireServer() end
                            end)
                            break
                        end
                        -- Find new target
                        local NewTarget = BotEngine.GetValidTarget(Humanoid)
                        BotEngine.LockedTarget = NewTarget
                    end

                    -- 2. Movement & Slapping
                    if BotEngine.LockedTarget and BotEngine.LockedTarget.Character then
                        local TRoot = BotEngine.LockedTarget.Character.Humanoid.RootPart
                        local Distance = (Humanoid.RootPart.Position - TRoot.Position).Magnitude
                        
                        Humanoid:MoveTo(BotEngine.GetPredictedPosition(TRoot))

                        if Distance < AcceptableDistance and not BotEngine.SlapCooldown then
                            BotEngine.SlapCooldown = true
                            local Anim = Humanoid:FindFirstChild("Animator") or Humanoid
                            local Track = Anim:LoadAnimation(ReplicatedStorage.Slap)
                            Track:Play()
                            Remotes.Slap.Swapper:FireServer(TRoot)
                            task.delay(0.6, function() BotEngine.SlapCooldown = false end)
                        end
                    end
                else
                    -- Lobby Logic
                    local _, glove = BotEngine.GetStats()
                    if glove ~= "Swapper" then
                        BotEngine.EquipGlove("Swapper")
                    else
                        BotEngine.WalkToPortal()
                    end
                end

                -- Dynamic Speed
                local Speed = BotSpeed * 2 - math.clamp(Humanoid.RootPart.AssemblyLinearVelocity.Magnitude, 0, BotSpeed)
                Humanoid.WalkSpeed = Speed
            end
            RunService.RenderStepped:Wait()
        end
    end)
end

-- [[ ANTI-ABUSE LOOP ]] --
task.spawn(function()
    while task.wait(0.3) do
        local Character = LocalPlayer.Character
        local Humanoid = Character and Character:FindFirstChild("Humanoid")
        
        if Humanoid and Character then
            if not BotEngine.IsInLobby(Character) then
                for _, v in ipairs(Character:GetChildren()) do
                    if v:IsA("BasePart") then v.CanTouch = false end
                end
            end

            local Root = Humanoid.RootPart
            if Root and (Root.Position.Magnitude > 1536 or Root.Position.Y < -20) then
                if Remotes.Misc.PlayerReset then Remotes.Misc.PlayerReset:FireServer() end
                task.wait(1)
            end
            
            if not Character:FindFirstChildWhichIsA("Tool") and LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool") then
                LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool").Parent = Character
            end
        end
    end
end)

return BotEngine
