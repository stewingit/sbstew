-- 4. Define Utility Commands
local Utils = {} 
getgenv().sbstew_Utils = Utils

Utils.GetStats = function()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    if stats then
        local slaps = stats:FindFirstChild("Slaps") and stats.Slaps.Value or 0
        local currentGlove = stats:FindFirstChild("Glove") and stats.Glove.Value or "None"
        
        if currentGlove == "Mace" or currentGlove == "Orbit" or currentGlove == "Extended" then
            Utils.AcceptableDistance = 21
        else
            Utils.AcceptableDistance = 15
        end

        return slaps, currentGlove
    end
    return 0, "None"
end

Utils.IsInLobby = function(Character)
    local Char = Character or LocalPlayer.Character
    return Char and Char:FindFirstChild("InLobby") ~= nil
end

Utils.WalkToPortal = function()
    local Character = LocalPlayer.Character
    if Character and Utils.IsInLobby(Character) then
        local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
        local LobbyFolder = Workspace:FindFirstChild("Lobby")
        local Portal = LobbyFolder and LobbyFolder:FindFirstChild("Teleport1")
        
        if Humanoid and Portal then
            Humanoid:MoveTo(Portal.Position)
        end
    end
end

Utils.EquipGlove = function(GloveName)
    local Lobby = Workspace:FindFirstChild("Lobby")
    if Lobby then
        local GloveObj = Lobby:FindFirstChild(GloveName)
        if GloveObj then
            local ClickDetector = GloveObj:FindFirstChildOfClass("ClickDetector")
            if ClickDetector then
                if fireclickdetector then
                    fireclickdetector(ClickDetector)
                elseif click_detector then
                    click_detector(ClickDetector)
                else
                    warn("Executor does not support fireclickdetector")
                end
            end
        end
    end
end


-- 5. BOT UTILITIES

-- Base Values
Utils.RoamRange = 120
Utils.MaxLockDistance = 180
Utils.AcceptableDistance = 15

Utils.GetZeroPosition = function()
    local arena = Workspace:FindFirstChild("Arena")
    if arena and arena:FindFirstChild("main island") then
        local grass = arena["main island"]:FindFirstChild("Grass")
        if grass then
            return grass.Position
        end
    end
    return Vector3.zero
end

-- Vector Math Utility
Utils.ReturnValidVector3Unit = function(Vector)
    if Vector.Magnitude == 0 then
        return Vector3.zero
    end
    return Vector.Unit
end

-- Common Target Validation
Utils.IsTargetValid = function(Character)
    if not Character then return false end
    
    local Player = Players:GetPlayerFromCharacter(Character)
    local PlayerName = Player and Player.Name or ""

    local InLobby = Utils.IsInLobby(Character)
    local Rock = Character:FindFirstChild("rock") or Character:FindFirstChild("megarock")
    local Reverse = Character:FindFirstChild("Reversed")
    local Skull = Character:FindFirstChild("Skull")
    local Counter = Character:FindFirstChild("Counterd")
    local Steve = Character:FindFirstChild("stevebody")
    local Ragdolled = Character:FindFirstChild("FakePart Right Arm")
    local Rob = Workspace:FindFirstChild(PlayerName) and Workspace[PlayerName]:FindFirstChild("RobTransformed")
    local Visible = Character:FindFirstChild("CarKeysCar") or (Character:FindFirstChild("Head") or Character:FindFirstChildWhichIsA("BasePart")).Transparency == 0
    
    local Head = Character:FindFirstChild("Head")
    local BuddyBox = Head and Head:FindFirstChild("BuddyBox")
    
    return not InLobby and not Rock and not Reverse and not Skull and not Counter and not Steve and not Ragdolled and not BuddyBox and not Rob and Visible
end

-- Common Character & Animation Setup
Utils.SetupBotSupport = function(Character, SlapAnimation)
    local Humanoid = Character:WaitForChild("Humanoid", 10)
    if not Humanoid then return nil, nil end
    
    local Animation = (Humanoid:FindFirstChild("Animator") or Humanoid):LoadAnimation(SlapAnimation)
    Humanoid.AutomaticScalingEnabled = false
    Humanoid.HipHeight = 0.1
    
    local Root = Character:FindFirstChild("HumanoidRootPart") or Character:FindFirstChild("Head")
    if Root then
        local Support = Root:FindFirstChild("Bot Support") or Instance.new("BodyPosition")
        Support.Position = Utils.GetZeroPosition()
        Support.MaxForce = Vector3.new(200, 0, 200)
        Support.Name = "Bot Support"
        Support.Parent = Root
    end
    
    return Humanoid, Animation
end

-- Safety Background Loop
Utils.StartSafetyLoop = function()
    getgenv().sbstew_SafetyActive = true
    task.spawn(function()
        while getgenv().sbstew_SafetyActive do
            local Character = LocalPlayer.Character
            local Root = Character and Character:FindFirstChild("HumanoidRootPart")
            local LocalHumanoid = Character and Character:FindFirstChildWhichIsA("Humanoid")
            local ResetRemote = getgenv().sbstew_Remotes.Misc.Reset()

            if Root and LocalHumanoid then
                if Root.Position.Magnitude > 1536 or Root.Position.Y < -20 then
                    if ResetRemote then
                        ResetRemote:FireServer()
                    end
                    LocalHumanoid.Health = 0
                    task.wait(2)
                end
            end
            task.wait(0.5)
        end
    end)
end

Utils.StopSafetyLoop = function()
    getgenv().sbstew_SafetyActive = false
end

return true
