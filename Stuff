local currentPlaceId = game.PlaceId
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- Ensure the game is loaded before proceeding
if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Define Places Globally
getgenv().sbstew_Places = {
    ["Lobby"]       = (currentPlaceId == 6403373529),
    ["Lobby2"]      = (currentPlaceId == 6403373529 or currentPlaceId == 9015014224),
    ["Lobby3"]      = (currentPlaceId == 6403373529 or currentPlaceId == 9015014224 or currentPlaceId == 11520107397),
    ["Barzil"]      = (currentPlaceId == 7234087065),
    ["UTG_Obby"]    = (currentPlaceId == 115782629143468),
    ["Application"] = (currentPlaceId == 16034567693),
    ["Plate"]       = (currentPlaceId == 106620300132058),
    ["Maze"]        = (currentPlaceId == 11828384869),
}

getgenv().sbstew_LoadedAnyTab = false 

-- Define shouldLoad Globally
getgenv().shouldLoad = function(locationList)
    local Places = getgenv().sbstew_Places
    if not Places then return false end
    
    for _, name in pairs(locationList) do
        if Places[name] then 
            getgenv().sbstew_LoadedAnyTab = true
            return true 
        end
    end
    return false
end

