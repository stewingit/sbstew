getgenv().sbstew_LoadedAnyTab = false 

-- Define shouldLoad Globally
getgenv().shouldLoad = function(locationList)
    local Places = getgenv().sbstew_Places
    for _, name in pairs(locationList) do
        if Places[name] then 
            getgenv().sbstew_LoadedAnyTab = true
            return true 
        end
    end
    return false
end

