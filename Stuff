-- Define Utility Commands
getgenv().sbstew_Utils = {}

function getgenv().sbstew_Utils.GetStats()
    local stats = LocalPlayer:FindFirstChild("leaderstats")
    local slaps = (stats and stats:FindFirstChild("Slaps")) and stats.Slaps.Value or 0
    local currentGlove = (stats and stats:FindFirstChild("Glove")) and stats.Glove.Value or "None"
    return slaps, currentGlove
end

function getgenv().sbstew_Utils.IsInLobby(Character)
    local Char = Character or LocalPlayer.Character
    return Char and Char:FindFirstChild("InLobby")
end

function getgenv().sbstew_Utils.WalkToPortal()
    local Character = LocalPlayer.Character
    if Character and getgenv().sbstew_Utils.IsInLobby(Character) then
        local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
        local Portal = Workspace.Lobby:FindFirstChild("Teleport1")
        if Humanoid and Portal then
            Humanoid:MoveTo(Portal.Position)
        end
    end
end

function getgenv().sbstew_Utils.EquipGlove(GloveName)
    local Lobby = Workspace:FindFirstChild("Lobby")
    if Lobby then
        local GloveObj = Lobby:WaitForChild(GloveName, 2)
        if GloveObj then
            local ClickDetector = GloveObj:FindFirstChildOfClass("ClickDetector")
            if ClickDetector then
                fireclickdetector(ClickDetector)
            end
        end
    end
end
