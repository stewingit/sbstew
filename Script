-- MAIN LOADER SCRIPT
local g = getgenv()
local currentPlaceId = game.PlaceId
local loaderUrl = "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Script"

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- 1. Auto Queue Logic
local q = queue_on_teleport or queueteleport or (syn and syn.queue_on_teleport)
if q and not g.sbstew_Queued then
    g.sbstew_Queued = true
    q('loadstring(game:HttpGet("' .. loaderUrl .. '"))()')
end

-- 2. Cleanup existing UI
if g.sbstew_Stewfield and typeof(g.sbstew_Stewfield.Destroy) == "function" then
    pcall(function() g.sbstew_Stewfield:Destroy() end)
end

-- 3. Initialise Stewfield
local Stewfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/stewingit/stewfield/refs/heads/main/source.lua'))()
g.sbstew_Stewfield = Stewfield

local Window = Stewfield:CreateWindow({
    Name = "Slap Battle Stew",
    Icon = "hand",
    LoadingTitle = "SBstew",
    SettingsId = "sbstew", 
})

g.sbstew_Window = Window

--- 4. External Logic & Place ID Storage ---
loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Places"))()

local createdTabs = {}

local function loadTab(url, name)
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    
    if not success then 
        warn("Failed to load tab: " .. tostring(result)) 
        return nil
    end
    return result
end

--- 5. Tab Loading Section ---
local isLobby3 = getgenv().sbstew_Places["Lobby3"]
local isLobby2 = getgenv().sbstew_Places["Lobby2"]
local BadgeTab

if isLobby3 then
    loadTab("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Info")
    
    BadgeTab = Window:CreateTab("Badges", "medal")
    BadgeTab:CreateLabel("Select a badge glove to load its tab")
end

if isLobby2 then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Farming"))()
    
    loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Trolling"))()
end

local function handleGlove(name, locations, url)
    if shouldLoad(locations) then
        getgenv().sbstew_LoadedAnyTab = true 
        
        if isLobby then
            BadgeTab:CreateButton({
                Name = name,
                Callback = function()
                    if not createdTabs[name] then
                        local newTab = loadTab(url, name)
                        if newTab and typeof(newTab) == "table" then
                            createdTabs[name] = newTab
                        end
                    end
                end,
            })
        else
            if not createdTabs[name] then
                local newTab = loadTab(url, name)
                if newTab then
                    createdTabs[name] = newTab
                end
            end
        end
    end
end

getgenv().sbstew_LoadedAnyTab = false

--- 6. Badge Glove Buttons ---
handleGlove("Admin", {"Lobby3", "Application"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Admin")
handleGlove("Bomb", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Bomb")
handleGlove("Boxer", {"Lobby3", "Barzil"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Boxer")
handleGlove("Plate", {"Lobby3", "Plate"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Plate")
handleGlove("UTG", {"Lobby3", "Barzil", "UTG_Obby"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/UTG")
handleGlove("Voodoo", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Voodoo")
handleGlove("Warp", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Warp")

-- Check if anything loaded
if not getgenv().sbstew_LoadedAnyTab then
    local ErrorTab = Window:CreateTab("Unsupported", "circle-alert")
    ErrorTab:CreateParagraph({
        Title = "Unsupported Experience",
        Content = "This script does not support the current game (ID: " .. currentPlaceId .. "). Please head over to Slap Battles to use this scripts features!"
    })
end

if not game:IsLoaded() then
    game.Loaded:Wait()
end
Window:LoadConfiguration()
