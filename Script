-- MAIN LOADER SCRIPT
local g = getgenv()
local currentPlaceId = game.PlaceId
local loaderUrl = "https://raw.githubusercontent.com/stewingit/sbstew/heads/main/Script"

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local q = queue_on_teleport or queueteleport or (syn and syn.queue_on_teleport)
if q and not g.sbstew_Queued then
    g.sbstew_Queued = true
    q('loadstring(game:HttpGet("' .. loaderUrl .. '"))()')
end

if g.sbstew_Stewfield and typeof(g.sbstew_Stewfield.Destroy) == "function" then
    pcall(function() g.sbstew_Stewfield:Destroy() end)
end

local libSource = game:HttpGet('https://raw.githubusercontent.com/stewingit/stewfield/refs/heads/main/source.lua')
local Stewfield = loadstring(libSource)()
g.sbstew_Stewfield = Stewfield

local Window = Stewfield:CreateWindow({
    Name = "Slap Battle Stew",
    Icon = "hand",
    LoadingTitle = "SBstew",
    SettingsId = "sbstew", 
})

g.sbstew_Window = Window

loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Stuff"))()

local shouldLoad = g.shouldLoad
local sbstew_Places = g.sbstew_Places

local createdTabs = {}

local function loadTab(url, name)
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    
    if not success then 
        warn("Failed to load tab: " .. tostring(result)) 
        return nil
    end
    return result
end

local isLobby1 = sbstew_Places["Lobby1"]
local isLobby2 = sbstew_Places["Lobby2"]
local isLobby3 = sbstew_Places["Lobby3"]
local isAnyLobby = isLobby1 or isLobby2 or isLobby3

local BadgeTab
local MiscTab

if isLobby3 then
    loadTab("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Info", "Info")
end

if isLobby3 then
    BadgeTab = Window:CreateTab("Badges", "medal")
    BadgeTab:CreateLabel("Select a badge glove to load its tab")
end

if isLobby3 then
    MiscTab = Window:CreateTab("Misc", "copy-plus")
    MiscTab:CreateLabel("Misc Features")
    MiscTab:CreateParagraph({
        Title = "Prevent Loading Lag",
        Content = "This tab is to prevent loading lag, press the below buttons to open up more tabs and amazing features!"
    })
end

local function handleTab(parentTab, name, locations, url)
    if parentTab and shouldLoad(locations) then
        g.sbstew_LoadedAnyTab = true 

        local NewButton
        NewButton = parentTab:CreateButton({
            Name = name,
            Callback = function()
                if NewButton then
                    NewButton:Destroy()
                end

                task.spawn(function()
                    if not createdTabs[name] then
                        local newTab = loadTab(url, name)
                        if newTab and typeof(newTab) == "table" then
                            createdTabs[name] = newTab
                        end
                    end
                end)
            end,
        })
    end
end

local function manageTab(name, locations, url, parentTab)
    local autoLoad = false
    
    for _, loc in ipairs(locations) do
        if sbstew_Places[loc] and not (loc == "Lobby1" or loc == "Lobby2" or loc == "Lobby3") then
            autoLoad = true
            break
        end
    end

    if autoLoad then
        g.sbstew_LoadedAnyTab = true
        loadTab(url, name)
    elseif parentTab then
        handleTab(parentTab, name, locations, url)
    end
end

g.sbstew_LoadedAnyTab = false

manageTab("Farming", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Farming", MiscTab)
manageTab("Trolling", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Trolling", MiscTab)

manageTab("Admin", {"Lobby3", "Application"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Admin", BadgeTab)
manageTab("Bomb", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Bomb", BadgeTab)
manageTab("Boxer", {"Lobby3", "Barzil"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Boxer", BadgeTab)
manageTab("Counter", {"Lobby3", "Maze"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Counter", BadgeTab)
manageTab("Elude", {"Lobby3", "Maze"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Elude", BadgeTab)
manageTab("Plate", {"Lobby3", "Plate"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Plate", BadgeTab)
manageTab("RNG", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/RNG", BadgeTab)
manageTab("UTG", {"Lobby3", "Barzil", "UTG_Obby"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/UTG", BadgeTab)
manageTab("Voodoo", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Voodoo", BadgeTab)
manageTab("Warp", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Warp", BadgeTab)

task.wait(0.5)
if not g.sbstew_LoadedAnyTab and not isAnyLobby then
    local ErrorTab = Window:CreateTab("Unsupported", "circle-alert")
    ErrorTab:CreateParagraph({
        Title = "Unsupported Experience",
        Content = "This script does not support the current game (ID: " .. currentPlaceId .. "). Please head over to Slap Battles to use this scripts features!"
    })
end

if not game:IsLoaded() then
    game.Loaded:Wait()
end
Window:LoadConfiguration()
