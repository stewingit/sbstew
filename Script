local g = getgenv()
local currentPlaceId = game.PlaceId
local loaderUrl = "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Script"

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- 1. Auto Queue Logic
local q = queue_on_teleport or queueteleport or (syn and syn.queue_on_teleport)
if q and not g.sbstew_Queued then
    g.sbstew_Queued = true
    q('loadstring(game:HttpGet("' .. loaderUrl .. '"))()')
end

-- 2. Cleanup existing UI
if g.sbstew_Stewfield and typeof(g.sbstew_Stewfield.Destroy) == "function" then
    pcall(function() g.sbstew_Stewfield:Destroy() end)
end

-- 3. Initialise Stewfield
local Stewfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/stewingit/stewfield/refs/heads/main/source.lua'))()
g.sbstew_Stewfield = Stewfield

local Window = Stewfield:CreateWindow({
    Name = "Slap Battle Stew",
    Icon = "hand",
    LoadingTitle = "SBstew",
    SettingsId = "sbstew", 
})

g.sbstew_Window = Window

--- 4. External Logic & Place ID Storage ---
loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Places"))()

local createdTabs = {}

local function loadTab(url, name)
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    
    if not success then 
        warn("Failed to load tab: " .. tostring(result)) 
        return nil
    end
    return result
end

--- 5. Tab Loading Section ---
local isLobby3 = getgenv().sbstew_Places["Lobby3"]
local isLobby2 = getgenv().sbstew_Places["Lobby2"]
local BadgeTab
local MiscTab

-- Load Info first
if isLobby3 or isLobby2 then
    loadTab("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Info")
end

BadgeTab = Window:CreateTab("Badges", "medal")
BadgeTab:CreateLabel("Select a badge glove to load its tab")

-- Misc Tab for Lobby 2 or 3
if isLobby3 or isLobby2 then
    MiscTab = Window:CreateTab("Misc", "copy-plus")
    MiscTab:CreateLabel("Misc Features")
    MiscTab:CreateParagraph({
        Title = "Prevent Loading Lag",
        Content = "This tab is to prevent loading lag, press the below buttons to open up more tabs and amazing features! NOTE: Some tabs may take a very long time to load, this is exactly why they're here. Just wait a few seconds"
    })
end

-- Unified Handle Function (Added destroyOnClick parameter)
local function handleTab(parentTab, name, locations, url, destroyOnClick)
    if shouldLoad(locations) then
        getgenv().sbstew_LoadedAnyTab = true 

        local NewButton
        NewButton = parentTab:CreateButton({
            Name = name,
            Callback = function()
                if not createdTabs[name] then
                    local newTab = loadTab(url, name)
                    if newTab and typeof(newTab) == "table" then
                        createdTabs[name] = newTab
                    end
                end
                
                -- Destroy logic for Misc Tab only
                if destroyOnClick and NewButton then
                    NewButton:Destroy()
                end
            end,
        })
    end
end

getgenv().sbstew_LoadedAnyTab = false

-- 6. Misc Buttons
handleTab(MiscTab, "Farming", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Farming", true)
handleTab(MiscTab, "Trolling", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Trolling", true)

-- 7. Badge Glove Buttons
handleTab(BadgeTab, "Admin", {"Lobby3", "Application"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Admin", false)
handleTab(BadgeTab, "Bomb", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Bomb", false)
handleTab(BadgeTab, "Boxer", {"Lobby3", "Barzil"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Boxer", false)
handleTab(BadgeTab, "Plate", {"Lobby3", "Plate"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Plate", false)
handleTab(BadgeTab, "UTG", {"Lobby3", "Barzil", "UTG_Obby"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/UTG", false)
handleTab(BadgeTab, "Voodoo", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Voodoo", false)
handleTab(BadgeTab, "Warp", {"Lobby2"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Tabs/Warp", false)

-- Check if anything loaded
if not getgenv().sbstew_LoadedAnyTab and not isLobby2 and not isLobby3 then
