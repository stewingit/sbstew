-- MAIN LOADER SCRIPT
local g = getgenv()
local currentPlaceId = game.PlaceId
local loaderUrl = "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Script"

-- 1. Auto Queue Logic
local q = queue_on_teleport or queueteleport or (syn and syn.queue_on_teleport)
if q and not g.sbstew_Queued then
    g.sbstew_Queued = true
    q('loadstring(game:HttpGet("' .. loaderUrl .. '"))()')
end

-- 2. Cleanup existing UI
if g.sbstew_Rayfield and typeof(g.sbstew_Rayfield.Destroy) == "function" then
    pcall(function() g.sbstew_Rayfield:Destroy() end)
end

-- 3. Initialise Rayfield
local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/stewingit/stewfield/refs/heads/main/source.lua'))()
g.sbstew_Rayfield = Rayfield

local Window = Rayfield:CreateWindow({
    Name = "Auto Get Gloves",
    Icon = "hand",
    LoadingTitle = "Gloves Interface",
    LoadingSubtitle = "Credits to stew",
    ConfigurationSaving = { Enabled = false },
    SettingsId = "sbstew", 
})

g.sbstew_Window = Window

--- 4. External Logic & Place ID Storage ---
loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Places"))()

-- Modified loadTab to return the tab created by the external script
local function loadTab(url)
    local success, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    if not success then 
        warn("Failed to load tab: " .. tostring(result)) 
        return nil
    end
    return result
end

--- 5. Tab Loading Section ---
local isLobby = getgenv().sbstew_Places["Lobby"]
local BadgeTab

-- Helper to find an existing tab by name
local function getExistingTab(name)
    local tabContainer = Window.Elements -- Adjusted based on typical Rayfield structure
    if tabContainer and tabContainer:FindFirstChild(name) then
        return tabContainer[name]
    end
    return nil
end

if isLobby then
    BadgeTab = Window:CreateTab("Badges", "medal")
    BadgeTab:CreateLabel("Select a badge glove to load its tab")
end

local function handleGlove(name, locations, url)
    if shouldLoad(locations) then
        if isLobby then
            BadgeTab:CreateButton({
                Name = name,
                Callback = function()
                    local existing = getExistingTab(name)
                    
                    if existing then
                        if typeof(existing) == "table" and existing.Select then
                            existing:Select()
                        end
                    else
                        local newTab = loadTab(url)
                        if newTab and typeof(newTab) == "table" and newTab.Select then
                            newTab:Select()
                        end
                    end
                end,
            })
        else
            if not getExistingTab(name) then
                loadTab(url)
            end
        end
    end
end

-- ADMIN GLOVE
handleGlove("Admin", {"Lobby", "Application"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Gloves/Admin")

-- BOXER GLOVE
handleGlove("Boxer", {"Lobby", "Barzil"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Gloves/Boxer")

-- UNTITLED TAG GLOVE
handleGlove("UTG", {"Lobby", "Barzil", "UTG_Obby"}, "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Gloves/UTG")


-- Check if anything loaded
if not getgenv().sbstew_LoadedAnyTab then
    local ErrorTab = getgenv().sbstew_Window:CreateTab("Unsupported", "circle-alert")
    ErrorTab:CreateParagraph({
        Title = "Unsupported Experience",
        Content = "This script does not support the current game (ID: " .. currentPlaceId .. "). Please head over to Slap Battles to use this scripts features!"
    })
end

Rayfield:LoadConfiguration()
