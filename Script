-- MAIN LOADER SCRIPT
local g = getgenv()
local currentPlaceId = game.PlaceId
local loaderUrl = "https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Script"

-- 1. Auto Queue Logic
local q = queue_on_teleport or queueteleport or (syn and syn.queue_on_teleport)
if q and not g.sbstew_Queued then
    g.sbstew_Queued = true
    q('loadstring(game:HttpGet("' .. loaderUrl .. '"))()')
end

-- 2. Cleanup existing UI
if g.sbstew_Rayfield and typeof(g.sbstew_Rayfield.Destroy) == "function" then
    pcall(function() g.sbstew_Rayfield:Destroy() end)
end

-- 3. Initialise Rayfield
local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/stewingit/stewfield/refs/heads/main/source.lua'))()
g.sbstew_Rayfield = Rayfield

local Window = Rayfield:CreateWindow({
    Name = "Auto Get Gloves",
    Icon = "hand",
    LoadingTitle = "Gloves Interface",
    LoadingSubtitle = "Credits to stew",
    ConfigurationSaving = { Enabled = false },
})

g.sbstew_Window = Window

--- 4. External Logic & Place ID Storage ---
loadstring(game:HttpGet("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Places"))()

local function loadTab(url)
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)
    if not success then warn("Failed to load tab: " .. err) end
end


local function loadTab(url)
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)
    if not success then warn("Failed to load tab: " .. err) end
end

--- 5. Tab Loading Section ---
-- ADMIN GLOVE
if shouldLoad({"Lobby", "Application"}) then
    loadTab("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Gloves/Admin")
end

-- BOXER GLOVE
if shouldLoad({"Lobby", "Barzil"}) then
    loadTab("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Gloves/Boxer")
end

-- UNTITLED TAG GLOVE
if shouldLoad({"Lobby", "Barzil", "UTG_Obby"}) then
    loadTab("https://raw.githubusercontent.com/stewingit/sbstew/refs/heads/main/Gloves/UTG")
end

-- Check if anything loaded
if not getgenv().sbstew_LoadedAnyTab then
    local ErrorTab = getgenv().sbstew_Window:CreateTab("Unsupported", "circle-alert")
    ErrorTab:CreateParagraph({
        Title = "Unsupported Experience",
        Content = "This script does not support the current game (ID: " .. currentPlaceId .. "). Please head over to Slap Battles to use this scripts features!"
    })
end

Rayfield:LoadConfiguration()
